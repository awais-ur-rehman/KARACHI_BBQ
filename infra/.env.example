# Karachi B.B.Q POS — example environment.
# Copy to .env (not committed) and edit before `docker compose up -d`.

# ─── Database ──────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD may contain special characters (@, #, /, etc.) — the
# backend entrypoint URL-encodes it automatically when building DATABASE_URL.
# Use a strong password; this is the only credential between the host and
# the local Postgres container.
POSTGRES_USER=kbbq
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=kbbq

# DATABASE_URL is built at container start from the variables above. Only
# set this explicitly if you point the backend at an external Postgres —
# and URL-encode the password yourself (e.g. @ → %40).
# DATABASE_URL=postgresql://kbbq:change-me-strong-password@db:5432/kbbq?schema=public

# ─── Backend ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# JWT signing secrets — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-32+char-random-secret-aaaaaaaaaaaaaa
JWT_REFRESH_SECRET=replace-with-different-32+char-random-secret-bb

# ─── Print (bootstrap defaults; runtime config lives in DB Settings) ───────
PRINT_MODE=thermal
PRINTER_IP=192.168.1.50
PRINTER_PORT=9100
PRINT_AGENT_URL=http://host.docker.internal:7878

# ─── Localization ──────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=PKR
TZ=Asia/Karachi

# ─── Backups (volume path inside the backup container) ────────────────────
BACKUP_DIR=/backups
